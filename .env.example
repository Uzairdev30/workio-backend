# =============================================
# WORKIO BACKEND — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# =============================================

# ─── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173

# ─── CORS (comma-separated allowed origins) ───
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/workio
# Production: MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/workio?retryWrites=true&w=majority

# ─── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Production: REDIS_TLS=true

# ─── JWT (use strong secrets — 64+ chars) ─────
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-for-jwt-access-tokens
JWT_REFRESH_SECRET=replace-this-with-a-different-very-long-random-secret-for-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@workio.io
SMTP_FROM_NAME=Workio

# ─── Super Admin Seed ─────────────────────────
SUPER_ADMIN_EMAIL=superadmin@workio.io
SUPER_ADMIN_PASSWORD=SuperAdmin@2024!
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Admin

# ─── Rate Limiting ────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── BullMQ ───────────────────────────────────
BULL_QUEUE_ATTEMPTS=3
BULL_QUEUE_BACKOFF=5000

# ─── Misc ─────────────────────────────────────
OTP_EXPIRY_MINUTES=10
INVITE_EXPIRY_HOURS=48
